{
  "name": "owen-editor",
  "version": "0.6.21",
  "description": "Markdown editing toolbar and Owen Graphite helpers for Obsidian.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "docs:screenshot": "node scripts/docs-screenshot.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "lint:obsidian": "eslint main.ts",
    "release:check": "node scripts/release-check.mjs",
    "release:preflight": "node scripts/release.mjs",
    "release:create": "node scripts/release.mjs --create",
    "sync:obsidian": "node scripts/sync-obsidian.mjs",
    "update:obsidian": "npm run build && npm run sync:obsidian"
  },
  "keywords": [
    "obsidian",
    "markdown",
    "editor",
    "toolbar",
    "owen-graphite"
  ],
  "author": "Owen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/towishy/owen-editor.git"
  },
  "bugs": {
    "url": "https://github.com/towishy/owen-editor/issues"
  },
  "homepage": "https://github.com/towishy/owen-editor#readme",
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@typescript-eslint/parser": "^8.59.1",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.20.2",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.2.9",
    "obsidian": "latest",
    "tslib": "^2.6.2",
    "typescript": "^5.4.3"
  }
}
